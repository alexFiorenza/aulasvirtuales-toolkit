    }

    class AuthenticationError {
        <<exception>>
    }

    AuthModule ..> AuthenticationError : raises

    %% ─────────────────────────────────────────────
    %% config.py (unchanged)
    %% ─────────────────────────────────────────────

    class ConfigModule {
        <<module: config>>
        +CONFIG_DIR: Path
        +CONFIG_FILE: Path
        +DEFAULT_DOWNLOAD_DIR: Path
        +load_config() dict
