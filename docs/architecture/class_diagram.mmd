    %% ═════════════════════════════════════════════
    %% converter.py  (REFACTORED — Strategy pattern)
    %% ═════════════════════════════════════════════

    class FileConverter {
        <<Protocol>>
        +supported_input: str
        +supported_output: str
        +convert(input_path: Path, output_dir: Path | None) Path
    }

    class DocxToPdfConverter {
        +supported_input = ".docx"
        +supported_output = ".pdf"
        +convert(input_path: Path, output_dir: Path | None) Path
    }

    class PptxToPdfConverter {
        +supported_input = ".pptx"
        +supported_output = ".pdf"
        +convert(input_path: Path, output_dir: Path | None) Path
    }

    class PdfToMarkdownConverter {
        +supported_input = ".pdf"
        +supported_output = ".md"
        +convert(input_path: Path, output_dir: Path | None) Path
    }

    DocxToPdfConverter ..|> FileConverter : implements
    PptxToPdfConverter ..|> FileConverter : implements
    PdfToMarkdownConverter ..|> FileConverter : implements

    %% ═════════════════════════════════════════════
    %% ocr.py  (REFACTORED — encapsulated in class)
    %% ═════════════════════════════════════════════

    class OcrConverter {
        -_provider: str
        -_model: str
        -_provider_kwargs: dict
        +__init__(provider: str, model: str, **kwargs)
        +convert(input_path: Path, output_format: str, output_dir: Path | None, on_page: Callable | None) Path
        +supported_extensions()$ set~str~
        -_get_llm() BaseChatModel
        -_ocr_image(image_bytes: bytes, mime_type: str, prompt: str) str
        -_pdf_to_images(pdf_path: Path) list~bytes~
        -_ensure_pdf(file_path: Path) tuple~Path_bool~
    }

    OcrConverter ..> FileConverter : uses for pre-conversion

    %% ═════════════════════════════════════════════
    %% services.py  (NEW — shared orchestration layer)
    %% ═════════════════════════════════════════════

    class ConversionPipeline {
        -_converters: dict
        -_ocr_converter: OcrConverter | None
        +__init__(ocr_config: OcrConfig | None)
        +convert(path: Path, to_format: str, output_dir: Path) Path
        +ocr_convert(path: Path, output_format: str, output_dir: Path, on_page: Callable | None) Path
    }

    class DownloadService {
        -_client: MoodleClient
        -_pipeline: ConversionPipeline
        +__init__(client: MoodleClient, pipeline: ConversionPipeline)
        +download_resource(course_id: int, resource_id: int, dest_dir: Path, to_format: str | None, file_filter: str | None, ocr: bool, on_page: Callable | None) list~Path~
    }

    ConversionPipeline --> FileConverter : chains
    ConversionPipeline --> OcrConverter : uses
    ConversionPipeline --> OcrConfig : reads
    DownloadService --> MoodleClient : uses
    DownloadService --> ConversionPipeline : delegates

    %% ═════════════════════════════════════════════
    %% Apps layer (CLI + MCP — thin wrappers)
    %% ═════════════════════════════════════════════

    class CLI_App {
        <<Typer · app.py>>
        +login_cmd() void
        +logout_cmd() void
        +status() void
        +courses() void
        +resources(course_id) void
        +read(course_id, resource_id) void
        +download(course_id, resource_id, ...) void
        +download_all(course_id, ...) void
        +events(course_id) void
        +grades(course_id) void
        +forums(course_id) void
        +discussions(forum_id) void
        +posts(discussion_id) void
        +config(...) void
        +clear_downloads() void
    }

    class MCP_Server {
        <<FastMCP · server.py>>
        +get_courses() tool
        +get_course_resources(course_id) tool
        +download(course_id, resource_id, ...) tool
        +read_resource(course_id, resource_id) tool
        +ocr_status(job_id) tool
        +get_upcoming_events(course_id) tool
        +get_grades(course_id) tool
        +get_forums(course_id) tool
        +get_forum_discussions(forum_id) tool
        +get_discussion_posts(discussion_id) tool
        +read_downloaded_file(filename) tool
        +clear_downloads(force) tool
    }

    class OcrJob {
        +id: str
        +filename: str
        +current_page: int
        +total_pages: int
        +status: str
        +result_path: str | None
        +error: str | None
    }

