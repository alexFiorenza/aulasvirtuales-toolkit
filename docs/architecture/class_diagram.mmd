    %% ─────────────────────────────────────────────
    %% converter.py — Strategy pattern for format conversion
    %% ─────────────────────────────────────────────

    class ConversionStrategy {
        <<Protocol>>
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class PdfToMarkdown {
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class DocxToMarkdown {
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class PptxToMarkdown {
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class DocxToPdf {
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class PptxToPdf {
        +convert(input_path: Path, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    class ConverterModule {
        <<module: converter>>
        +STRATEGIES: dict
        +convert(input_path: Path, to_format: str, output_dir: Path|None, reporter: ProgressReporter|None) Path
    }

    ConversionStrategy <|.. PdfToMarkdown
    ConversionStrategy <|.. DocxToMarkdown
    ConversionStrategy <|.. PptxToMarkdown
    ConversionStrategy <|.. DocxToPdf
    ConversionStrategy <|.. PptxToPdf
    ConverterModule --> ConversionStrategy : dispatches via STRATEGIES

