classDiagram
    direction TB

    %% ─────────────────────────────────────────────
    %% session.py — Shared infrastructure
    %% ─────────────────────────────────────────────

    class MoodleSession {
        +http: httpx.Client
        +sesskey: str
        +__init__(session_cookie: str)
        -_fetch_sesskey() str
        +ajax(method: str, args: dict) dict
    }

    class MoodleClientError {
        <<exception>>
    }

    MoodleSession ..> MoodleClientError : raises

    %% ─────────────────────────────────────────────
    %% client.py — Facade (delegates to services)
    %% ─────────────────────────────────────────────

    class MoodleClient {
        <<facade>>
        -_session: MoodleSession
        -_courses: CoursesService
        -_forums: ForumsService
        -_events: EventsService
        -_grades: GradesService
        -_assignments: AssignmentsService
        +__init__(session_cookie: str)
        +http: httpx.Client
        +get_courses() list~Course~
        +get_course_contents(course_id: int) list~Section~
        +get_forums(course_id: int) list~Resource~
        +get_forum_discussions(forum_cmid: int, limit: int) list~Discussion~
        +get_discussion_posts(discussion_id: int) list~ForumPost~
        +get_upcoming_events(course_id: int|None, limit: int) list~Event~
        +get_grades(course_id: int) list~GradeItem~
        +get_grades_with_status(course_id: int) list~GradeItem~
        +get_assignment_details(assignment_cmid: int) AssignmentDetails
    }

    MoodleClient *-- MoodleSession
    MoodleClient *-- CoursesService
    MoodleClient *-- ForumsService
    MoodleClient *-- EventsService
    MoodleClient *-- GradesService
    MoodleClient *-- AssignmentsService

    %% ─────────────────────────────────────────────
    %% services/ — Domain services
    %% ─────────────────────────────────────────────

    class CoursesService {
        -_session: MoodleSession
        +get_courses() list~Course~
        +get_course_contents(course_id: int) list~Section~
    }

    class ForumsService {
        -_session: MoodleSession
        -_courses: CoursesService
        +get_forums(course_id: int) list~Resource~
        +get_forum_discussions(forum_cmid: int, limit: int) list~Discussion~
        +get_discussion_posts(discussion_id: int) list~ForumPost~
    }

    class EventsService {
        -_session: MoodleSession
        +get_upcoming_events(course_id: int|None, limit: int) list~Event~
    }

    class GradesService {
        -_session: MoodleSession
        -_assignments: AssignmentsService
        +get_grades(course_id: int) list~GradeItem~
        +get_grades_with_status(course_id: int) list~GradeItem~
    }

    class AssignmentsService {
        -_session: MoodleSession
        +get_assignment_details(assignment_cmid: int) AssignmentDetails
    }

    CoursesService --> MoodleSession
    ForumsService --> MoodleSession
    ForumsService --> CoursesService : get_forums delegates
    EventsService --> MoodleSession
    GradesService --> MoodleSession
    GradesService --> AssignmentsService : get_grades_with_status delegates
    AssignmentsService --> MoodleSession

    %% ─────────────────────────────────────────────
    %% parsers.py — Pure HTML parsing functions
    %% ─────────────────────────────────────────────

    class ParsersModule {
        <<module: parsers>>
        +strip_html(text: str) str
        +clean_html_cell(raw: str) str
        +parse_grade_table(html: str) list~tuple~
        +parse_forum_discussions(html: str, limit: int) list~Discussion~
        +parse_assignment_page(html: str) tuple
    }

    ForumsService ..> ParsersModule : uses
    GradesService ..> ParsersModule : uses
    AssignmentsService ..> ParsersModule : uses

    %% ─────────────────────────────────────────────
    %% models.py — All domain data classes
    %% ─────────────────────────────────────────────

    class Course {
        +id: int
        +fullname: str
        +url: str
    }

    class Resource {
        +id: int
        +name: str
        +module: str
        +url: str|None
        +type_label: str
    }

    class Section {
        +id: int
        +number: int
        +name: str
        +resources: list~Resource~
    }

    class Event {
        +id: int
        +name: str
        +course_name: str
        +module: str
        +timestamp: int
        +url: str
        +action: str
        +date: str
    }

    class Discussion {
        +id: int
        +title: str
    }

    class ForumPost {
        +id: int
        +subject: str
        +author: str
        +message: str
        +timestamp: int
        +date: str
        +clean_message: str
    }

    class GradeItem {
        +name: str
        +grade: str
        +range: str
        +percentage: str
        +feedback: str
        +status: str
    }

    class SubmissionComment {
        +author: str
        +date: str
        +content: str
    }

    class AssignmentDetails {
        +grade: str
        +comments: list~SubmissionComment~
        +submission_status: str
    }

    Section o-- Resource : contains
    AssignmentDetails o-- SubmissionComment : contains

    CoursesService --> Course : returns
    CoursesService --> Section : returns
    ForumsService --> Resource : returns
    ForumsService --> Discussion : returns
    ForumsService --> ForumPost : returns
    EventsService --> Event : returns
    GradesService --> GradeItem : returns
    AssignmentsService --> AssignmentDetails : returns

    %% ─────────────────────────────────────────────
    %% events.py — Observer pattern for progress reporting
    %% ─────────────────────────────────────────────

    class ProgressReporter {
        <<Protocol>>
        +on_step(message: str, output: Path) None
        +on_error(message: str) None
    }

    class RichReporter {
        <<CLI implementation>>
        -_console: Console
        +on_step(message: str, output: Path) None
        +on_error(message: str) None
    }

    class NullReporter {
        <<silent / MCP>>
        +on_step(message: str, output: Path) None
        +on_error(message: str) None
    }

    ProgressReporter <|.. RichReporter
    ProgressReporter <|.. NullReporter

    %% Who accepts a reporter
    ConverterModule ..> ProgressReporter : convert() accepts optional reporter
    DownloaderModule ..> ProgressReporter : download_file() accepts optional reporter
    GradesService ..> ProgressReporter : get_grades_with_status() accepts optional reporter

