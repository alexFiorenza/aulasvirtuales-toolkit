{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "chore", "section": "Miscellaneous", "hidden": true },
    { "type": "ci", "section": "CI/CD", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true }
  ],
  "packages": {
    "apps/aulasvirtuales-cli": {
      "release-type": "python",
      "component": "aulasvirtuales-cli",
      "include-paths": ["apps/aulasvirtuales-cli"]
    },
    "apps/aulasvirtuales-mcp": {
      "release-type": "python",
      "component": "aulasvirtuales-mcp",
      "include-paths": ["apps/aulasvirtuales-mcp"],
      "extra-files": [
        "apps/aulasvirtuales-mcp/src/aulasvirtuales_mcp/__init__.py"
      ]
    }
  }
}
